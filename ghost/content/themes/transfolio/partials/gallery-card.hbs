<article class="gallery-card {{post_class}}">
  <a class="gallery-card__image" href="{{url}}" aria-label="Open {{title}}">
    {{#if feature_image}}
      <img src="{{img_url feature_image size="m"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy">
    {{else}}
      <img src="{{asset "images/placeholder-01.svg"}}" alt="Placeholder image for {{title}}" loading="lazy">
    {{/if}}
    <span class="gallery-card__open" aria-hidden="true">↗</span>
  </a>
  <div class="gallery-card__meta">
    <h3><a href="{{url}}">{{title}}</a></h3>
    <span>{{date format="MMM YYYY"}}</span>
  </div>
</article>
