.DS_Store
Thumbs.db

# Environment and local overrides
.env
.env.*
!.env.example
docker-compose.override.yml

# Editor/IDE files
.idea/
.vscode/
*.swp
*.swo

# Legacy Grav runtime; Ghost is now the active CMS.
/site/

# Ghost runtime state and uploaded media live in Docker-managed volumes.
/ghost/content/data/
/ghost/content/images/
/ghost/content/logs/
/ghost/content/adapters/

# Keep the authored theme, while allowing Ghost to install its bundled themes.
/ghost/content/themes/*
!/ghost/content/themes/transfolio/
!/ghost/content/themes/transfolio/**

# Keep the authored routing configuration only.
/ghost/content/settings/*
!/ghost/content/settings/routes.yaml

# Runtime artifacts
*.log
*.tmp
