.DS_Store
Thumbs.db

# Environment and local overrides
.env
.env.*
!.env.example
docker-compose.override.yml

# Editor/IDE files
.idea/
.vscode/
*.swp
*.swo

# Grav core and default packages are provisioned into the bind mount by Docker.
/site/*
!/site/user/
/site/user/*

# Runtime artifacts
*.log
*.tmp
/site/cache/
/site/logs/
/site/tmp/
/site/backup/
/site/images/
/site/vendor/

# Keep only the authored configuration, pages, and theme in Git.
!/site/user/config/
/site/user/config/*
!/site/user/config/site.yaml
!/site/user/config/system.yaml
!/site/user/pages/
!/site/user/pages/**
!/site/user/themes/
/site/user/themes/*
!/site/user/themes/transfolio/
!/site/user/themes/transfolio/**
